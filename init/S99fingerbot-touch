#!/bin/sh

DAEMON="/usr/sbin/fingerbot-touch.py"
PIDFILE="/var/run/fingerbot-touch.pid"
LOGFILE="/var/log/fingerbot-touch.log"

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "fingerbot-touch already running"
        return 0
    fi

    echo "Starting fingerbot-touch"
    nohup "$DAEMON" >>"$LOGFILE" 2>&1 &
    echo $! >"$PIDFILE"

    sleep 1

    if kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "fingerbot-touch started, PID $(cat "$PIDFILE")"
    else
        echo "fingerbot-touch failed to start"
        rm -f "$PIDFILE"
        return 1
    fi
}

stop() {
    echo "Stopping fingerbot-touch"

    if [ -f "$PIDFILE" ]; then
        PID="$(cat "$PIDFILE")"
        kill "$PID" 2>/dev/null || true
        sleep 1
        kill -9 "$PID" 2>/dev/null || true
        rm -f "$PIDFILE"
    fi

    pkill -f "/usr/sbin/fingerbot-touch.py" 2>/dev/null || true
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "fingerbot-touch is running, PID $(cat "$PIDFILE")"
        return 0
    fi

    echo "fingerbot-touch is stopped"
    return 1
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        sleep 1
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
